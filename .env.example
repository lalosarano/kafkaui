# Optional configuration for `docker compose up`. Copy to `.env` and edit.
# Compose auto-reads a `.env` file in this directory — no other changes needed.

# Seed a "default" cluster on first boot so the UI connects automatically.
# Leave unset to start with no clusters and add them through the UI.
#   Docker Desktop (Kafka on your host): host.docker.internal:9092
#   LAN broker:                          192.168.x.x:9092
#   Remote cluster:                      broker.example.com:9092
# KAFKAGUI_BOOTSTRAP_SERVERS=host.docker.internal:9092

# Browser origins allowed to call the API (comma-separated).
# KAFKAGUI_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
